homeserver:
  url: "https://matrix.example.com"
  domain: "example.com"

openclaw:
  # URL of the Openclaw gateway — can be remote (different host/network)
  url: "http://openclaw.example.com:18789"
  token: "your-gateway-token"
  agentSyncIntervalMinutes: 10
  streamTimeoutSeconds: 60

appservice:
  port: 9993
  # "127.0.0.1" is correct when Synapse runs on the same machine as this appservice.
  # Set to "0.0.0.0" (or a specific interface IP) if Synapse is on a different host.
  bindAddress: "127.0.0.1"
  controlRoomAlias: "openclaw-control"

database:
  url: "postgresql://user:password@localhost:5432/matrix_openclaw"
